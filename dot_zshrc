eval 
GRAPH_AC_ZSH_SETUP_PATH=/Users/nassu/Library/Caches/@graphprotocol/graph-cli/autocomplete/zsh_setup && test -f $GRAPH_AC_ZSH_SETUP_PATH && source $GRAPH_AC_ZSH_SETUP_PATH; # graph autocomplete setup

